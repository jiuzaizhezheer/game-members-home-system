PROJECT_NAME="Game Members Home System"
VERSION=1.0.0
DEBUG=true
ENV=local

# postgresql
POSTGRES_USER=???
POSTGRES_PASSWORD=???
POSTGRES_DB=???
POSTGRES_HOST=???
POSTGRES_PORT=???

# mongodb
MONGO_ROOT_USER=???
MONGO_ROOT_PASSWORD=???
MONGO_DB=???
MONGO_HOST=???
MONGO_PORT=???

# redis
REDIS_HOST=???
REDIS_PORT=???
REDIS_DB=???

# rabbitmq
RABBITMQ_USER=???
RABBITMQ_PASSWORD=???
RABBITMQ_HOST=???
RABBITMQ_PORT=???

# jwt
SECRET_KEY=???
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# mail
MAIL_USERNAME=your_account@qq.com
MAIL_PASSWORD=your_smtp_auth_code
MAIL_FROM=your_account@qq.com
MAIL_PORT=465
MAIL_SERVER=smtp.qq.com
MAIL_FROM_NAME="Game Members Home"
MAIL_STARTTLS=false
MAIL_SSL_TLS=true
USE_CREDENTIALS=true
VALIDATE_CERTS=true
